INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777175,
  'Autodesk Inventor Professional 2025 PC – 1 Jahr / 1 Gerät',
  '\\nAutodesk Inventor Professional 2025: Umfassende 3D-CAD-Lösung für mechanische Konstruktion \\nAutodesk Inventor Professional 2025 setzt neue Maßstäbe in der pofessionellen 3D-CAD-Software für Maschinenbau, Anlagenbau und Produktentwicklung. Diese leistungsstarke Lösung kombiniert parametrische Modellierung mit direkten Bearbeitungstechniken und erweiterten Analysefunktionen. Mit verbesserten Workflows für Großbaugruppen, optimierten Zeichnungserstellungsprozessen und erweiterten Simulationstools unterstützt Sie Inventor Professional durchgängig vom Konzept bis zur fertigen technischen Dokumentation. \\n \\n \\nInnovative Funktionen für professionelle Konstruktionsergebnisse \\nAutodesk Inventor Professional 2025 integriert fortschrittliche Konstruktionswerkzeuge mit praktischen Arbeitsabläufe',
  '\\nAutodesk Inventor Professional 2025 – Professionelle 3D Konstruktionssoftware \\nDas Autodesk Inventor Professional 2025 Abonnement bietet umfassende Werkzeuge für professionelle 3D-Mechanikkonstruktion und Produktentwicklung. Erstellen Sie präzise 3D-Modelle, führen Sie Bewegungsimulationen durch und generieren Sie technische Dokumentation mit der führenden CAD-Software für Maschinenbau und mechanische Konstruktion. Die Software unterstützt parametrisches Design, direkte Modellierung und erweiterte Blechkonstruktion für komplexe Fertigungsteile. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Parametrische 3D-Modellierung für flexible Konstruktionen \\n Erweiterte FEM-Berechnungen und Bewegungsimulationen \\n Automatische Zeichnungserstellung aus 3D-Modellen \\n Integrierte Werkzeuge für Blech-',
  1999,
  NULL,
  'SK24-1-1-1-1-1-1',
  'Grafiksoftware',
  '/images/placeholder.jpg',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777178,
  'Autodesk Revit 2025 PC',
  '\\n \\n \\n \\nAutodesk Revit 2025 PC \\nDie führende BIM-Software für Architektur, Ingenieurbau und Gebäudetechnik mit revolutionären 2025-Features \\n \\n \\n \\n \\n \\n \\n \\nBuilding Information Modeling (BIM) revolutioniert die Baubranche. Dabei spielt Autodesk Revit 2025 eine zentrale Rolle als Branchenstandard. Denn diese Software vereint Architektur, Tragwerksplanung und Gebäudetechnik in einer einzigen Plattform. Außerdem profitieren Sie von parametrischer Modellierung – nicht nur für einfache Gebäude. Vielmehr ermöglicht Revit komplexe Bauwerke mit automatischer Koordination zwischen allen Gewerken. Zusätzlich erhalten Sie mit Version 2025 bahnbrechende Verbesserungen für Toposolid-Modellierung, Sheet Collections und Bewehrungsplanung. Folglich optimieren Sie Ihre BIM-Workflows erheblich. \\',
  '\\nAutodesk Revit 2025 – Professionelle BIM Software für Gebäudeplanung \\nDas Autodesk Revit 2025 Abonnement bietet umfassende Building Information Modeling (BIM) Werkzeuge für Architekten, Ingenieure und Bauplaner. Erstellen Sie präzise 3D-Modelle, koordinieren Sie Gewerke und optimieren Sie Ihren Planungsprozess mit der führenden BIM-Lösung für die Gebäudebranche. Die Software unterstützt Sie durchgängig von der Konzeption bis zur Ausführungsplanung mit intelligenten Parametern und automatisierten Aktualisierungen. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Umfassende BIM-Funktionen für alle Planungsphasen \\n Echtzeit-Kollaboration mit Projektbeteiligten \\n Automatische Aktualisierung aller Ansichten und Dokumente \\n Parametrisches Design für flexible Anpassungen \\n \\n \\n \\n \\nSie erhalt',
  0,
  NULL,
  'SK24-11',
  'Grafiksoftware',
  'https://softwareking24.de/wp-content/uploads/2025/12/Autodesk_Revit_2026.webp',
  1,
  999,
  datetime('now')
);

