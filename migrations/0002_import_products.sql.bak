  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777114,
  'Ashampoo WinOptimizer 26 PC Vollversion',
  '\\nAshampoo WinOptimizer 26: Komplette Lösung für PC-Optimierung und Systempflege mit SoftwareKing24.de \\nAshampoo WinOptimizer 26 stellt die bisher umfassendste Version der beliebten Systemoptimierungs-Software dar. Mit vollständig überarbeiteten Modulen und neuen Funktionen bietet diese All-in-One-Lösung alles, was Sie für die Pflege und Beschleunigung Ihres Computers benötigen. Die Software kombiniert leistungsstarke Bereinigungs- und Optimierungswerkzeuge mit einer intuitiven Benutzeroberfläche, die sowohl Einsteigern als auch erfahrenen Anwendern optimale Arbeitsbedingungen bietet. \\n \\n \\nLeistungsstarke Funktionen für maximale Systemperformance \\nAshampoo WinOptimizer 26 integriert über 40 spezialisierte Module, die systematisch alle Aspekte der PC-Optimierung abdecken. Von der grund',
  '\\nAshampoo WinOptimizer 26 – Umfassende PC Optimierung und Systempflege \\nDer Ashampoo WinOptimizer 26 bietet eine komplett überarbeitete Suite zur Systemoptimierung und PC-Pflege. Mit über 40 Modulen entfernt die Software überflüssige Dateien, optimiert die Registry, beschleunigt Ihren Computer und erhöht die Systemsicherheit. Die intuitive Benutzeroberfläche führt Sie durch alle Optimierungsprozesse und stellt sicher, dass auch weniger erfahrene Anwender ihren PC problemlos warten können. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Umfassende Systembereinigung und Performance-Steigerung \\n Automatische Wartungsfunktionen für optimale PC-Leistung \\n Erweiterte Datenschutz- und Sicherheitsfunktionen \\n Benutzerfreundliche Oberfläche mit One-Click-Optimierung \\n \\n \\n \\n \\nSie erhalten den ',
  0,
  NULL,
  'SK24-1',
  'Systemsoftware',
  'https://softwareking24.de/wp-content/uploads/2025/12/Ashampoo_WinOptimizer_26.webp',
  1,
  999,
  datetime('now')
);

