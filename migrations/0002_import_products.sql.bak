INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789775509,
  'McAfee LiveSafe – 1 Jahr / Unbegrenzte Geräte',
  '\\n \\nMcAfee LiveSafe: 1 Jahr Schutz für unbegrenzte Geräte – Die ultimative Cybersicherheitslösung \\nIn der heutigen hypervernetzten Welt ist die digitale Sicherheit keine Option mehr, sondern eine absolute Notwendigkeit. Daher stehen Heimanwender, Familien und kleine Unternehmen vor der ständigen Herausforderung, eine wachsende Anzahl von Geräten – vom Smartphone über den Laptop bis hin zum Smart-Home-Gerät – effektiv vor komplexen Cyberbedrohungen zu schützen. Die Lösung muss umfassend, leistungsstark und vor allem unkompliziert sein. Folglich präsentieren wir Ihnen McAfee LiveSafe, die Premium-Sicherheitslösung, die genau diese Anforderungen erfüllt und Ihnen 1 Jahr lang Schutz für unbegrenzte Geräte bietet. \\n \\n \\nKernfunktionen für umfassenden Onlineschutz \\nMcAfee LiveSafe geht weit',
  '\\nMcAfee LiveSafe – Umfassender Schutz für alle Ihre Geräte \\nMcAfee LiveSafe bietet erstklassigen Schutz für unbegrenzte Geräte mit einer einzigen Abonnementlösung. Diese Premium-Sicherheitssoftware kombiniert leistungsstarke Antivirus-Technologie mit fortschrittlichem Identitätsschutz und einer robusten Firewall. Schützen Sie Ihre Windows-PCs, Macs, Smartphones und Tablets vor Viren, Ransomware, Phishing-Angriffen und anderen Cyberbedrohungen mit einer benutzerfreundlichen Lösung, die im Hintergrund arbeitet. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Schutz für unbegrenzte Geräte mit einem Produktcode \\n Echtzeit-Antivirus und Anti-Malware Schutz \\n Fortschrittlicher Identitätsdiebstahl-Schutz \\n Einfache Verwaltung aller Geräte über ein zentrales Dashboard \\n \\n \\n \\n \\nSie erhalten d',
  8999,
  4999,
  'SK24-540006',
  'Antivirus > McAfee',
  'https://softwareking24.de/wp-content/uploads/2025/11/Mcafee.jpg',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789775526,
  'Norton Secure VPN (PC, Mac, Mobile) 1 Jahr / 1 Gerät',
  '\\n \\n \\n \\nNorton Secure VPN Lizenz Key – 1 Jahr / 1 Gerät \\nSichere VPN-Verbindung für PC, Mac und Mobile-Geräte – Privates Surfen leicht gemacht \\n \\n \\n \\n \\n \\n \\n \\nWer heute sicher und anonym im Internet surfen möchte, braucht einen zuverlässigen VPN-Dienst. Deshalb ist der Norton Secure VPN Lizenz Key für 1 Jahr und 1 Gerät die richtige Wahl für Sie. Diese bewährte Lösung von Norton schützt Ihre Daten wirksam vor Hackern, Tracking und neugierigen Blicken. Außerdem verschlüsselt die Software Ihre komplette Internet-Verbindung. Dadurch bleiben Ihre Online-Aktivitäten privat – egal ob Sie am PC, Mac oder mit dem Smartphone unterwegs sind. \\nBei SoftwareKing24 kaufen Sie den echten Norton-Code zum fairen Preis. Darüber hinaus erhalten Sie Ihren Lizenz-Schlüssel sofort per E-Mail. Folgli',
  '\\nNorton Secure VPN – Bank-level Sicherheit für Ihr Gerät \\nDas Norton Secure VPN Abonnement bietet professionellen Schutz Ihrer Online-Privatsphäre mit bank-level Verschlüsselung für ein Gerät Ihrer Wahl. Diese zuverlässige VPN-Lösung schützt Ihre persönlichen Daten in öffentlichen WLAN-Netzwerken, blockiert lästige Werbung und verhindert die Verfolgung Ihrer Online-Aktivitäten. Die automatische Aktivierung sorgt für mühelosen Schutz von Anfang an. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Bank-level 256-Bit Verschlüsselung für maximale Sicherheit \\n Automatischer Schutz in öffentlichen WLAN-Netzwerken \\n Werbeblocker für ungestörtes Surfen \\n Keine Protokollierung Ihrer Online-Aktivitäten \\n \\n \\n \\n \\nSie erhalten den Produktcode für Norton Secure VPN nach dem Kauf in Ihrem Kundenkont',
  5999,
  2499,
  'SK24-540004',
  'Antivirus',
  'https://softwareking24.de/wp-content/uploads/2025/11/Norton-1.webp',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789775745,
  'NordVPN Standard Lizenz Key – 1 Jahr / 10 Geräte',
  '\\n \\n \\n \\nNordVPN Standard Lizenz Key – 1 Jahr / 10 Geräte \\nSichere VPN-Verbindung für privates Surfen, Streaming und maximalen Daten-Schutz \\n \\n \\n \\n \\n \\n \\n \\nWer heute sicher im Internet surfen möchte, braucht einen guten VPN-Dienst. Deshalb ist der NordVPN Standard Lizenz Key für 1 Jahr und 10 Geräte die perfekte Wahl für Sie. Diese bewährte Lösung schützt Ihre Daten wirksam vor neugierigen Blicken, Hackern und Tracking. Außerdem verschlüsselt die Software Ihre komplette Internet-Verbindung. Dadurch surfen Sie anonym und sicher – egal ob zu Hause oder unterwegs. \\nBei SoftwareKing24 kaufen Sie den echten NordVPN-Code zum fairen Preis. Darüber hinaus erhalten Sie Ihren Lizenz-Schlüssel sofort per E-Mail. Folglich können Sie direkt loslegen und bis zu 10 Geräte gleichzeitig schützen',
  '\\nNordVPN Standard – Professioneller Onlineschutz für alle Geräte \\nDas NordVPN Standard Abonnement bietet umfassenden Schutz Ihrer Online-Privatsphäre auf bis zu 10 Geräten gleichzeitig. Mit diesem VPN-Service genießen Sie sichere Internetverbindungen, umgehen geografische Beschränkungen und schützen Ihre sensiblen Daten vor neugierigen Blicken. Die intuitive Benutzeroberfläche macht die Nutzung selbst für Einsteiger einfach und komfortabel. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Gleichzeitiger Schutz für bis zu 10 verschiedene Geräte \\n Verschlüsselte Internetverbindung für maximale Privatsphäre \\n Zugang zu globalen Inhalten ohne geografische Einschränkungen \\n Hohe Geschwindigkeiten für Streaming und Downloads \\n \\n \\n \\n \\nSie erhalten den Produktcode für NordVPN Standard nach de',
  15499,
  8999,
  'SK24-540003',
  'VPN',
  'https://softwareking24.de/wp-content/uploads/2025/11/NORD-VPN-1.webp',
  1,
  999,
  datetime('now')
);

