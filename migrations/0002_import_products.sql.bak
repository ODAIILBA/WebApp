) VALUES (
  7931789777588,
  'Microsoft Windows 11 Professional',
  '\\n \\n \\n \\nMicrosoft Windows 11 Professional \\nDas moderne Betriebssystem für Business, Sicherheit und Produktivität \\n \\n \\n \\n \\n \\n \\n \\nModerne Geschäftsanforderungen erfordern moderne Betriebssysteme. Genau hier setzt Microsoft Windows 11 Professional an. Denn diese Edition wurde speziell für Unternehmen und anspruchsvolle Anwender entwickelt. Außerdem bietet sie weit mehr als die Home-Version. Vielmehr bekommen Sie professionelle Features wie BitLocker-Verschlüsselung, Hyper-V-Virtualisierung und Remote Desktop. Zusätzlich profitieren Sie von Domain-Join-Funktionen – nicht nur für große Konzerne. \\nBei SoftwareKing24 erhalten Sie Ihre originale Windows 11 Pro Lizenz zum Bestpreis. Der Produktschlüssel kommt direkt nach dem Kauf per E-Mail zu Ihnen. Besonders praktisch ist dabei, dass',
  '',
  5999,
  1799,
  'SK24-54000101',
  'Angebote',
  'https://softwareking24.de/wp-content/uploads/2025/11/Windows-11-Professional-1.webp',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777932,
  'Microsoft Office 2024 Professional Plus',
  '\\n \\n \\n \\nMicrosoft Office 2024 Professional Plus kaufen – Die ultimative Business-Suite mit KI-Power \\nVollständiges Office-Paket mit Copilot, Access, Publisher und allen Premium-Features für Unternehmen \\n \\n \\n \\n \\nSie suchen nach der leistungsstärksten Office-Lösung für Ihr Unternehmen oder anspruchsvolle professionelle Projekte? Microsoft Office 2024 Professional Plus ist die Premium-Version der bewährten Office-Suite und bietet Ihnen das komplette Paket aus Produktivitäts-Tools, erweiterten Business-Anwendungen und innovativen KI-Features. Bei SoftwareKing24.de erhalten Sie Ihre Office 2024 Pro Plus Lizenz als Dauerlizenz mit sofortiger Lieferung per E-Mail – professionell, schnell und zuverlässig. \\nDie Professional Plus Edition ist speziell für Unternehmen, IT-Profis und Power-Us',
  '\\n \\nMicrosoft Office 2024 Professional Plus – Umfassende Bürosoftware Suite \\nDie Microsoft Office 2024 Professional Plus Edition bietet die komplette Palette professioneller Büroanwendungen als dauerhafte Lizenz ohne Abonnement. Diese All-in-One-Lösung verbindet bewährte Funktionen mit innovativen Neuerungen für maximale Produktivität im Berufsalltag. Mit dieser Office-Version erhalten Sie alle essentiellen Tools für Textverarbeitung, Tabellenkalkulation, Präsentationen und E-Mail-Management in einer leistungsstarken Suite. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Komplette Office-Suite mit Word, Excel, PowerPoint, Outlook und mehr \\n Dauerhafte Nutzung ohne monatliche Abokosten \\n Neueste Funktionen und verbesserte Performance \\n Ideal für Unternehmen, Selbstständige und Privatanwend',
  6999,
  1999,
  'SK24-540001050',
  'Angebote',
  'https://softwareking24.de/wp-content/uploads/2025/11/2024-Pro-plus.jpg',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789778115,
  'Microsoft Office 2016 Home and Business – Mac',
  '\\n \\n \\n \\n \\n \\nMicrosoft Office 2016 Home and Business – Mac \\nErledigen Sie Ihren Büroalltag am Mac strukturiert, effizient und nachvollziehbar. Denn mit Word, Excel, PowerPoint, OneNote und Outlook bündeln Sie Text, Tabellen, Präsentationen, Notizen sowie E‑Mail und Kalender in einer Suite – und zwar so, dass Sie Aufgaben im Home‑Office, im Unternehmen oder als Selbstständige sauber organisieren können. \\n \\nProduktdetails & Programmliste: SoftwareKing24 Produktseite \\n \\n \\nWord \\nExcel \\nPowerPoint \\nOutlook \\nOneNote \\n \\nJetzt Office 2016 Home & Business für Mac ansehen \\n \\nTrust-Badges: \\nDigital (ESD) \\nSetup & Aktivierung \\nBusiness‑Fokus (Outlook) \\n \\nEinleitung: Office‑Arbeit am Mac – klar, kompatibel und organisiert \\nIm Arbeitsalltag zählt vor allem eines: Sie möchten Doku',
  '',
  2999,
  NULL,
  'SK24-123456789',
  'Microsoft Office 2016',
  'https://softwareking24.de/wp-content/uploads/2025/11/Microsoft-Office-2016-Home-and-Business-–-Mac.webp',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789779259,
  'Microsoft Visual Studio 2026 – Enterprise',
  '\\n \\n \\n \\nMicrosoft Visual Studio 2026 Enterprise \\nDie ultimative Entwicklungsumgebung für professionelle Teams mit KI-gestützter Programmierung und Enterprise-Features \\n \\n \\n \\n \\n \\n \\n \\nSoftwareentwicklung erreicht mit Microsoft Visual Studio 2026 Enterprise eine neue Dimension. Denn diese IDE wurde speziell für komplexe Unternehmensprojekte konzipiert. Außerdem bietet sie weit mehr als Standard-Entwicklungstools. Vielmehr bekommen Sie eine Komplettlösung mit GitHub Copilot-Integration, erweiterten Debugging-Tools und Live-Architektursvalidierung. Zusätzlich profitieren Sie von IntelliTrace, Code-Metriken und automatisierten Testframeworks – nicht nur für kleine Projekte. \\nBei SoftwareKing24 erhalten Sie Ihre originale Visual Studio 2026 Enterprise Lizenz zum Bestpreis. Folglich k',
  '\\nMicrosoft Visual Studio 2026 Professional – Professionelle Entwicklungsumgebung \\nDie Visual Studio 2026 Professional Edition bietet Entwicklern eine umfassende IDE mit modernsten Tools für effiziente Softwareentwicklung. Mit integrierten KI-Features, erweiterten Debugging-Funktionen und nahtloser Cloud-Integration beschleunigen Sie Ihre Entwicklungsprozesse deutlich. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n KI-gestützte Code-Vervollständigung für höhere Produktivität \\n Erweiterte Debugging- und Diagnosetools für robusten Code \\n Nahtlose Integration mit Azure und Cloud-Diensten \\n Performance-Optimierung für große Projekte und Teams \\n \\n \\n \\n \\nSie erhalten den Produktcode für Visual Studio 2026 Professional nach dem Kauf in Ihrem Kundenkonto und per E-Mail. Dauerhafte Lizenz ohne',
  32999,
  17999,
  'SK24-00067868',
  'Entwicklung',
  'https://softwareking24.de/wp-content/uploads/2025/12/Microsoft_Visual_Studio_2026_Enterprise.webp',
  1,
  999,
  datetime('now')
);

