INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777068,
  'Adobe Acrobat Pro DC 2019 Pc Vollversion',
  '\\n \\n \\n \\nAdobe Acrobat Pro DC 2019 – PC Vollversion \\nProfessionelle PDF-Bearbeitung ohne Abo – Einmalzahlung für dauerhafte Nutzung mit allen Enterprise-Features \\n \\n \\n \\n \\n \\n \\n \\nPDF-Dokumente bestimmen den modernen Geschäftsalltag. Dabei benötigen Sie mehr als einen einfachen Reader. Adobe Acrobat Pro DC 2019 bietet die vollständige Lösung für professionelle PDF-Bearbeitung ohne monatliche Abo-Kosten. Denn diese Vollversion wurde speziell für Unternehmen und Selbstständige entwickelt. Außerdem bietet sie weit mehr als Standard-PDF-Tools. Vielmehr bekommen Sie eine Komplettlösung mit OCR-Texterkennung, Formularerstellung und erweiterten Bearbeitungsfunktionen. Zusätzlich profitieren Sie von digitalen Signaturen und Dokumentenvergleich – nicht nur für einfache Aufgaben. \\nBei Softw',
  '\\nAdobe Acrobat Pro DC 2019 – Umfassende PDF Bearbeitung für professionelle Anforderungen \\nAdobe Acrobat Pro DC 2019 ist die professionelle Lösung für alle PDF-Anforderungen im Büroalltag und Business-Umfeld. Erstellen, bearbeiten und verwalten Sie PDF-Dokumente mit präzisen Werkzeugen und erweiterten Funktionen. Die Software bietet umfassende Bearbeitungsmöglichkeiten für Text, Bilder und Formulare in PDF-Dateien. Ideal für Unternehmen, Behörden und professionelle Anwender, die zuverlässige PDF-Werkzeuge ohne Abonnement-Verpflichtung benötigen. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Vollständige PDF-Bearbeitung von Text und Bildern \\n Erstellung interaktiver PDF-Formulare \\n Dokumentensicherheit mit Passwortschutz und Verschlüsselung \\n Konvertierung in verschiedene Dateiformate \\n ',
  5999,
  2699,
  'SK24-000000',
  'Büroanwendungen',
  'https://softwareking24.de/wp-content/uploads/2025/11/photo_2025-12-10_18-05-06.webp',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777077,
  'Autodesk Revit 2026 (PC) – 1Jahr/1Gerät Abo',
  '\\nAutodesk Revit 2026: Revolutionäre BIM-Lösung für moderne Planungsprozesse mit Softwareking24.de \\nAutodesk Revit 2026 setzt neue Maßstäbe in der Building Information Modeling (BIM) Software für Architekten, Ingenieure und Bauunternehmen. Diese professionelle Lösung unterstützt Sie durchgängig von der ersten Konzeptidee bis zur fertigen Ausführungsplanung. Mit verbesserten Kollaborationsfunktionen und erweiterten Analysewerkzeugen gestalten Sie Ihren Planungsprozess effizienter als je zuvor und meistern selbst komplexeste Bauvorhaben mit höchster Präzision. \\n \\n \\nInnovative Funktionen für herausragende Planungsergebnisse \\nAutodesk Revit 2026 bringt entscheidende Verbesserungen für Ihren täglichen Workflow. Die Software kombiniert leistungsstarke Modellierungswerkzeuge mit intelligente',
  '\\nAutodesk Revit 2026 – Professionelle BIM Software für Gebäudeplanung \\nDas Autodesk Revit 2026 Abonnement bietet umfassende Building Information Modeling (BIM) Werkzeuge für Architekten, Ingenieure und Bauplaner. Erstellen Sie präzise 3D-Modelle, koordinieren Sie Gewerke und optimieren Sie Ihren Planungsprozess mit der führenden BIM-Lösung für die Gebäudebranche. Ideal für komplexe Bauprojekte und kooperative Planungsprozesse. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Umfassende BIM-Funktionen für alle Planungsphasen \\n Echtzeit-Kollaboration mit Projektbeteiligten \\n Automatische Aktualisierung aller Ansichten und Dokumente \\n Parametrisches Design für flexible Anpassungen \\n \\n \\n \\n \\nSie erhalten den Produktcode für Autodesk Revit 2026 nach dem Kauf in Ihrem Kundenkonto und per E-M',
  2799,
  NULL,
  'SK24-0',
  'Grafiksoftware',
  'https://softwareking24.de/wp-content/uploads/2025/12/Autodesk_Revit_2026.webp',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777079,
  'Adobe Photoshop Elements 2022 (PC) Vollversion',
  '\\nAdobe Photoshop Elements 2022: Intelligente Bildbearbeitung mit KI-Technologie günstig kaufen als Vollversion bei SoftwareKing24.de \\nAdobe Photoshop Elements 2022 setzt neue Maßstäbe in der benutzerfreundlichen Bildbearbeitung durch den Einsatz fortschrittlicher KI-Technologie. Diese Software macht professionelle Fotobearbeitung für jeden zugänglich, der seine Fotos optimieren, organisieren und kreativ gestalten möchte. Mit automatisierten Funktionen und intelligenten Vorschlägen erreichen Sie beeindruckende Ergebnisse ohne komplizierte Bearbeitungsschritte – perfekt für Hobbyfotografen, Familien und kreative Enthusiasten. \\n \\n \\nRevolutionäre KI-Funktionen für perfekte Fotos \\nAdobe Photoshop Elements 2022 nutzt künstliche Intelligenz, um Ihre Fotobearbeitung zu vereinfachen und zu be',
  '\\nAdobe Photoshop Elements 2022 – KI-gestützte Bildbearbeitung \\nAdobe Photoshop Elements 2022 revolutioniert die Fotobearbeitung für Einsteiger und Hobbyfotografen mit intelligenten KI-Funktionen. Die Software bietet automatische Fotoverbesserung, intelligente Organisation Ihrer Bilder und kreative Gestaltungsmöglichkeiten ohne komplizierte Einstellungen. Perfekt für alle, die professionelle Ergebnisse ohne umfangreiches Vorwissen erzielen möchten. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n KI-gestützte automatische Fotoverbesserung für perfekte Ergebnisse \\n Intelligente Bildorganisation mit Gesichts- und Motiverkennung \\n Über 60 kreative Gestaltungsvorlagen für einzigartige Collagen \\n Einfache Bedienung ohne Vorkenntnisse in Bildbearbeitung \\n \\n \\n \\n \\nSie erhalten den Produktcode ',
  14999,
  5499,
  'SK24-00',
  'Grafiksoftware',
  'https://softwareking24.de/wp-content/uploads/2025/12/Adobe_Photoshop_Elements_2022_PC.webp',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777080,
  'Microsoft Visual Studio 2026 – Professional',
  '\\n \\n \\n \\nMicrosoft Visual Studio 2026 Professional \\nDie neueste professionelle Entwicklungsumgebung für moderne Software-Entwicklung \\n \\n \\n \\n \\n \\n \\n \\nSoftware-Entwicklung erfordert leistungsstarke und zuverlässige Werkzeuge. Dabei müssen moderne IDEs komplexe Projekte, Teams und Technologien unterstützen. Genau hier setzt Microsoft Visual Studio 2026 Professional an. Denn diese IDE bietet alle Tools für professionelle Entwickler und kleine Teams. Außerdem unterstützt sie .NET, C++, Python, JavaScript und viele weitere Sprachen. Zusätzlich profitieren Sie von KI-gestütztem IntelliCode, Cloud-Integration und erweiterten Debugging-Features. Folglich entwickeln Sie schneller, effizienter und fehlerfreier – von Desktop-Apps bis zu Cloud-Lösungen. \\nBei SoftwareKing24 erhalten Sie Ihre ',
  '\\nMicrosoft Visual Studio 2026 Professional – Professionelle Entwicklungsumgebung \\nDie Visual Studio 2026 Professional Edition bietet Entwicklern eine umfassende IDE mit modernsten Tools für effiziente Softwareentwicklung. Mit integrierten KI-Features, erweiterten Debugging-Funktionen und nahtloser Cloud-Integration beschleunigen Sie Ihre Entwicklungsprozesse deutlich. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n KI-gestützte Code-Vervollständigung für höhere Produktivität \\n Erweiterte Debugging- und Diagnosetools für robusten Code \\n Nahtlose Integration mit Azure und Cloud-Diensten \\n Performance-Optimierung für große Projekte und Teams \\n \\n \\n \\n \\nSie erhalten den Produktcode für Visual Studio 2026 Professional nach dem Kauf in Ihrem Kundenkonto und per E-Mail. Dauerhafte Lizenz ohne',
  28999,
  12999,
  'SK24-00067867',
  'Entwicklung',
  'https://softwareking24.de/wp-content/uploads/2025/12/Microsoft_Visual_Studio_2026_Professional.webp',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777084,
  'Autodesk AutoCAD 2025 MAC',
  '\\n \\n \\n \\n \\n \\nAutodesk AutoCAD 2025 MAC \\nEntwickeln Sie präzise 2D-Zeichnungen und aussagekräftige 3D-Modelle auf dem Mac – strukturiert, nachvollziehbar und teamfähig. Außerdem arbeiten Sie mit dem DWG-Standard, sodass Ihre Entwürfe in Architektur, Maschinenbau und Planung konsistent bleiben. \\n \\nDWG-Workflows \\n2D & 3D \\nmacOS-optimiert \\nTeam & Doku \\n \\nJetzt Autodesk AutoCAD 2025 MAC auf SoftwareKing24 ansehen \\n \\nTrust-Badges: \\nOriginal-Software \\nSichere Zahlung \\nSchnelle Zustellung \\n \\n \\n \\n \\nEinleitung: AutoCAD 2025 auf dem Mac – klarer planen, sauber dokumentieren \\nAutodesk AutoCAD 2025 MAC richtet sich an Anwender, die technische Zeichnungen nicht nur erstellen, sondern auch langfristig verwalten, prüfen und weitergeben müssen. Dadurch profitieren Sie von einem CAD-S',
  '\\nAutodesk AutoCAD 2025 – Professionelle CAD Software für technische Zeichnungen \\nDas Autodesk AutoCAD 2025 Abonnement bietet umfassende Werkzeuge für präzise 2D-Zeichnungen und 3D-Modellierung in Architektur, Maschinenbau und technischer Planung. Erstellen Sie detaillierte technische Zeichnungen, konstruieren Sie komplexe 3D-Modelle und optimieren Sie Ihre Design-Workflows mit der branchenführenden CAD-Software. Die aktuelle Version 2025 bringt verbesserte Performance, neue Automatisierungsfunktionen und erweiterte Collaboration-Tools für effizienteres Arbeiten. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Präzise 2D-Zeichnungserstellung mit professionellen Werkzeugen \\n Leistungsstarke 3D-Modellierung für komplexe Konstruktionen \\n Automatisierte Workflows und intelligente Zeichnungsfunk',
  0,
  NULL,
  'SK24-00000',
  'Büroanwendungen',
  'https://softwareking24.de/wp-content/uploads/2025/11/Autodesk-AutoCAD-2025-MAC.webp',
  1,
  999,
  datetime('now')
);

