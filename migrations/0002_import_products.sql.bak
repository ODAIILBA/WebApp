  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777153,
  'Ashampoo WinOptimizer 27 PC Vollversion 1 Gerät',
  '\\n \\nAshampoo WinOptimizer 27 PC Vollversion (1 Gerät) \\nMachen Sie Windows schneller, sauberer und sicherer. Außerdem erhalten Sie neue Automatik-Funktionen, Profile für Arbeit und Gaming sowie Tools, die Datenschutz-Spuren gezielt entfernen. \\n \\n1 Gerät \\nAutomatik & Profile \\nCleaner & Privacy Traces \\n \\n \\n \\n \\n \\nProdukt-Eindruck: Oberfläche & Module \\nDie folgenden Visuals stammen direkt vom Hersteller (Screenshots/Media). Dadurch sehen Sie sofort, wie Systemanalyse, Cleaner und Module aufgebaut sind. \\n \\n \\n \\n \\n \\n \\n \\n \\n \\n \\n \\nQuellen: Ashampoo Media \\nund Ashampoo Overview. \\n \\n \\n \\n \\n \\n \\n \\nWindows wird jeden Tag genutzt. Deshalb sammeln sich mit der Zeit viele Daten an, die niemand bewusst braucht: Temp-Dateien, alte Protokolle und Spuren von Apps. \\nGenau hier se',
  '\\nAshampoo WinOptimizer 27 – Umfassende PC Optimierung und Systempflege \\nDer Ashampoo WinOptimizer 27 bietet eine komplett überarbeitete Suite zur Systemoptimierung und PC-Pflege. Mit über 40 Modulen entfernt die Software überflüssige Dateien, optimiert die Registry, beschleunigt Ihren Computer und erhöht die Systemsicherheit. Die intuitive Benutzeroberfläche führt Sie durch alle Optimierungsprozesse und stellt sicher, dass auch weniger erfahrene Anwender ihren PC problemlos warten können. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Umfassende Systembereinigung und Performance-Steigerung \\n Automatische Wartungsfunktionen für optimale PC-Leistung \\n Erweiterte Datenschutz- und Sicherheitsfunktionen \\n Benutzerfreundliche Oberfläche mit One-Click-Optimierung \\n \\n \\n \\n \\nSie erhalten den ',
  2499,
  NULL,
  'SK24-1-1-1',
  'Systemsoftware',
  'https://softwareking24.de/wp-content/uploads/2025/11/ASH-Win-O-27.webp',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777170,
  'Techsmith Camtasia Studio 6 PC Vollversion',
  '\\n \\n \\n \\n \\n \\nTechSmith Camtasia Studio 6 PC Vollversion kaufen – Screen Recording & Video-Editing für Tutorials \\nCamtasia Studio 6 ist eine bewährte Lösung, um Bildschirmaufnahmen zu erstellen, Präsentationen zu vertonen und Lernvideos professionell zu schneiden – ideal für \\nSchulungen, Software-Demos und E-Learning. \\n \\n \\n \\n \\n \\n \\n \\nKurzüberblick \\n \\n Aufnahme: Bildschirm + Audio, ideal für Tutorials & Demos \\n Bearbeitung: Schneiden, Texte/Callouts, einfache Effekte \\n Einsatz: Schulungen, YouTube, Support-Videos, Produktdemos \\n Für PC: Klassische Desktop-Software \\n \\n \\n \\nPasst Camtasia 6 zu dir? \\nWenn du eine stabile, klassische Camtasia-Version suchst, mit der du Bildschirmaufnahmen strukturierst und schnell zu einem fertigen Video \\nkommst, ist Camtasia Studio 6 eine',
  '\\nTechsmith Camtasia Studio 6 – Professionelle Bildschirmaufnahme und Video Bearbeitung \\nCamtasia Studio 6 ist eine umfassende Lösung für Bildschirmaufnahmen und Video Bearbeitung, ideal für die Erstellung von Tutorials, Schulungsvideos und Präsentationen. Die Software kombiniert leistungsstarke Aufnahmefunktionen mit intuitiven Bearbeitungswerkzeugen. Erfassen Sie Ihren Bildschirm in hoher Qualität, fügen Sie Kommentare und Effekte hinzu und exportieren Sie Ihre Videos in verschiedenen Formaten für unterschiedliche Plattformen. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Einfache Bildschirmaufnahme in hoher Qualität \\n Intuitive Video Bearbeitung mit zahlreichen Effekten \\n Integration von Webcam-Aufnahmen und Audio \\n Vielfältige Exportoptionen für verschiedene Plattformen \\n \\n \\n \\n \\',
  1499,
  NULL,
  'SK24-1-1-1-1',
  'Videosoftware',
  'https://softwareking24.de/wp-content/uploads/2025/11/TECH.webp',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777173,
  'Autodesk Inventor Professional 2026 PC – 1 Jahr / 1 Gerät',
  '\\n \\n \\n \\nAutodesk Inventor Professional 2026 PC \\nProfessionelle 3D-CAD-Software für mechanische Konstruktion, Simulation und Produktdokumentation – 1 Jahr Lizenz \\n \\n \\n \\n \\n \\n \\n \\nMechanische Konstruktion erfordert präzise Werkzeuge für komplexe Anforderungen. Dabei spielt Autodesk Inventor Professional 2026 eine zentrale Rolle im Maschinen- und Anlagenbau. Denn diese Software vereint parametrische Modellierung, Blechkonstruktion, Rohrleitungsplanung und FEM-Simulation in einer Plattform. Außerdem profitieren Sie von automatischer Zeichnungsableitung – nicht nur für einfache Bauteile. Vielmehr ermöglicht Inventor komplexe Baugruppen mit Tausenden Komponenten. Zusätzlich erhalten Sie mit Version 2026 revolutionäre Verbesserungen für Pattern-Vorschau, Sheet Metal-Werkzeuge und Revit-',
  '\\nAutodesk Inventor Professional 2026 – Professionelle 3D Konstruktionssoftware \\nDas Autodesk Inventor Professional 2026 Abonnement bietet umfassende Werkzeuge für professionelle 3D-Mechanikkonstruktion und Produktentwicklung. Erstellen Sie präzise 3D-Modelle, führen Sie Bewegungsimulationen durch und generieren Sie technische Dokumentation mit der führenden CAD-Software für Maschinenbau und mechanische Konstruktion. Die Software unterstützt parametrisches Design, direkte Modellierung und erweiterte Blechkonstruktion für komplexe Fertigungsteile. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Parametrische 3D-Modellierung für flexible Konstruktionen \\n Erweiterte FEM-Berechnungen und Bewegungsimulationen \\n Automatische Zeichnungserstellung aus 3D-Modellen \\n Integrierte Werkzeuge für Blech-',
  2799,
  NULL,
  'SK24-1-1-1-1-1',
  'Grafiksoftware',
  'https://softwareking24.de/wp-content/uploads/2025/12/Autodesk_Inventor_Professional_2026.webp',
  1,
  999,
