INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789780291,
  'Microsoft Server 2025 Essentials',
  '\\n \\n \\n \\nMicrosoft Server 2025 Essentials \\nDie ideale Server-Lösung für kleine Unternehmen – bis zu 25 Benutzer und 50 Geräte ohne CAL-Lizenzierung \\n \\n \\n \\n \\n \\n \\n \\nKleine Unternehmen benötigen zuverlässige Server-Infrastruktur ohne komplizierte Lizenzierung. Genau hier setzt Microsoft Server 2025 Essentials an. Denn diese Edition wurde speziell für Organisationen mit bis zu 25 Benutzern und 50 Geräten entwickelt. Außerdem entfällt die komplexe CAL-Lizenzierung komplett – alle Zugriffe sind bereits in der Serverlizenz enthalten. Folglich sparen Sie nicht nur Geld, sondern auch administrativen Aufwand. Zudem erhalten Sie alle essentiellen Server-Funktionen wie Active Directory, Dateifreigaben und Remote-Zugriff in einem Paket. \\nBei SoftwareKing24 erhalten Sie Ihre originale Micros',
  '',
  49999,
  27499,
  'SK24-54000299',
  'Angebote',
  'https://softwareking24.de/wp-content/uploads/2025/12/Server-2025-Essentials.jpeg',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789780299,
  'Microsoft Windows Server 2025 Standard Core Add-on',
  '\\n \\n \\n \\nMicrosoft Windows Server 2025 Standard Core Add-on \\nSkalieren Sie Ihre Server-Infrastruktur flexibel – zusätzliche Core-Lizenzen für Prozessoren mit mehr als 16 Kernen \\n \\n \\n \\n \\n \\n \\n \\nModerne Server-Prozessoren verfügen häufig über mehr als 16 Kerne. Genau hier wird das Windows Server 2025 Standard Core Add-on unverzichtbar. Denn Microsofts Lizenzmodell erfordert, dass jeder physische Core lizenziert sein muss. Außerdem reicht die Basis-Lizenz nur für die ersten 16 Cores aus. Folglich benötigen Sie für jeden weiteren Core über diesem Minimum zusätzliche 2-Core-Packs. Zudem skaliert diese Lizenzierung flexibel mit Ihrer Hardware – Sie kaufen nur, was Sie wirklich brauchen. Darüber hinaus ermöglicht das Core Add-on die vollständige Ausnutzung leistungsstarker Multi-Core-Pr',
  'Microsoft Windows Server 2025 Standard Core Add-On (2–24 Core) zur rechtssicheren Erweiterung Ihrer Server-Lizenz. Original Microsoft Lizenz, sofort lieferbar.',
  0,
