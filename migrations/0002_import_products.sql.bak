  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789775753,
  'Kaspersky Anti-Virus Lizenz Key – 1 Jahr / 1 Gerät',
  '\\n \\n \\n \\nKaspersky Anti-Virus Lizenz Key – 1 Jahr / 1 Gerät \\nStarker Schutz gegen Viren, Malware und Online-Gefahren für Ihren Windows-PC \\n \\n \\n \\n \\n \\n \\n \\nWer heute im Internet unterwegs ist, braucht einen guten Schutz vor digitalen Gefahren. Deshalb ist der Kaspersky Anti-Virus Lizenz Key für 1 Jahr und 1 Gerät die richtige Wahl für Sie. Diese bewährte Lösung schützt Ihren Windows-PC wirksam vor Viren, Trojanern, Ransomware und anderen Schadprogrammen. Außerdem arbeitet die Software leise im Hintergrund. Dadurch können Sie sicher surfen, ohne sich um technische Details kümmern zu müssen. \\nBei SoftwareKing24 kaufen Sie den echten Code zum fairen Preis. Darüber hinaus erhalten Sie Ihren Schlüssel sofort per E-Mail. Folglich können Sie direkt loslegen. Das Angebot ist ideal für all',
  '\\nKaspersky Anti-Virus – Zuverlässiger Schutz vor Viren und Cyber-Bedrohungen \\nKaspersky Anti-Virus bietet starken Basisschutz für Ihren Computer gegen Viren, \\nMalware, Ransomware und weitere digitale Bedrohungen. Die Software arbeitet mit \\nmoderner Erkennungstechnologie, um Ihr System in Echtzeit zu sichern. \\n \\nIhre wichtigsten Vorteile: \\n \\n Echtzeit-Schutz vor Viren, Malware & Ransomware \\n Minimaler Einfluss auf Systemressourcen \\n Automatische Updates für dauerhaften Schutz \\n Einfache Bedienung ohne technische Kenntnisse \\n \\nSie erhalten den Produktcode direkt nach Ihrem Kauf per E-Mail. \\n',
  4999,
  2499,
  'SK24-540002',
  'Antivirus',
  'https://softwareking24.de/wp-content/uploads/2025/11/Kaspersky.webp',
  1,
  999,
  datetime('now')
);

