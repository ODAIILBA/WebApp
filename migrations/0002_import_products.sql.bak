) VALUES (
  7931789777097,
  'Nitro PDF Pro 10 Pc Vollversion',
  '\\nNitro PDF Pro 10 Pc Vollversion: Professionelle PDF-Lösung ohne Abonnement-Verpflichtung nur bei SoftwareKing24.de \\nNitro PDF Pro 10 Pc Vollversion stellt eine wirtschaftliche Alternative zu teuren Abonnement-basierten PDF-Lösungen dar, ohne dabei Kompromisse bei Funktionalität und Leistung einzugehen. Diese vollständig ausgestattete PDF-Software bietet alle wesentlichen Werkzeuge für die tägliche Arbeit mit PDF-Dokumenten in Unternehmen, Behörden und privaten Haushalten. Mit einer benutzerfreundlichen Oberfläche und leistungsstarken Bearbeitungsfunktionen ermöglicht Nitro PDF Pro 10 eine effiziente Dokumentenverwaltung ohne laufende Kosten. \\n \\n \\nUmfassende Funktionen für professionelle PDF-Bearbeitung \\nNitro PDF Pro 10 Pc Vollversion kombiniert essenzielle PDF-Funktionen mit einer ',
  '\\nNitro PDF Pro 10 Perpetual – Umfassende PDF Bearbeitung ohne Abonnement \\nNitro PDF Pro 10 Perpetual bietet eine komplett ausgestattete PDF-Lösung für professionelle Dokumentenbearbeitung ohne monatliche Gebühren. Erstellen, bearbeiten und konvertieren Sie PDF-Dateien mit leistungsstarken Werkzeugen und einer intuitiven Benutzeroberfläche. Die Software ermöglicht Text- und Bildbearbeitung, Formularerstellung, Dokumentensicherheit und nahtlose Konvertierung in verschiedene Formate. Ideal für Unternehmen und Privatanwender, die eine kostengünstige Alternative zu teuren Abonnement-Modellen suchen. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Vollständige PDF-Bearbeitung ohne Abonnement-Kosten \\n Intuitive Benutzeroberfläche für einfache Bedienung \\n Konvertierung zwischen PDF und Office-Form',
  4999,
  1199,
  'SKU-7931789777097',
  'Büroanwendungen',
  'https://softwareking24.de/wp-content/uploads/2025/12/Nitro_PDF_Pro_10_Perpetual_Pc.webp',
  1,
  999,
  datetime('now')
);

INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789777102,
  'Autodesk 3ds Max 2026 PC – 1 Jahr / 1 Gerät',
  '\\nAutodesk 3ds Max 2026: Innovative 3D-Lösung für professionelle Visualisierungen mit SoftwareKing24.de \\nAutodesk 3ds Max 2026 definiert neue Standards in der professionellen 3D-Modellierung, Animation und Visualisierung. Diese branchenführende Software bietet ein umfassendes Werkzeugset für die Erstellung atemberaubender 3D-Inhalte in den Bereichen Architektur, Produktdesign, Spieleentwicklung und Filmproduktion. Mit verbesserten Workflows, erweiterten Modellierungstechniken und optimierten Rendering-Funktionen unterstützt 3ds Max 2026 Kreative bei der Umsetzung ihrer visuellen Visionen mit höchster Präzision und Effizienz. \\n \\n \\nLeistungsstarke Funktionen für professionelle 3D-Produktion \\nAutodesk 3ds Max 2026 integriert fortschrittliche Technologien und workflowspezifische Werkzeuge',
  '\\nAutodesk 3ds Max 2026 – Professionelle 3D Modellierung und Visualisierung \\nDas Autodesk 3ds Max 2026 Abonnement bietet umfassende Werkzeuge für professionelle 3D-Modellierung, Animation und Visualisierung. Erstellen Sie beeindruckende 3D-Modelle, realistische Animationen und hochwertige Renderings für Architektur, Produktdesign und Medienproduktion. Die Software kombiniert leistungsstarke Modellierungstechniken mit fortschrittlichen Rendering-Engines für herausragende visuelle Ergebnisse in verschiedenen Branchen und Anwendungsbereichen. \\n \\n \\n \\nIhre wichtigsten Vorteile: \\n \\n Umfassende 3D-Modellierungswerkzeuge für komplexe Geometrien \\n Leistungsstarke Animations- und Rigging-Funktionen \\n Integrierte Render-Engines für fotorealistische Ergebnisse \\n Spezialisierte Werkzeuge für ',
  3999,
  NULL,
  'SK24-00000000',
  'Grafiksoftware',
  'https://softwareking24.de/wp-content/uploads/2025/12/Autodesk_3ds_Max_2026-1.webp',
  1,
  999,
  datetime('now')
);

