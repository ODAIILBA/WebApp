INSERT OR REPLACE INTO products (
  id, name, description, short_description, price, sale_price, 
  sku, category, image_url, in_stock, stock_quantity, created_at
) VALUES (
  7931789780327,
  'Microsoft Windows Server 2022 Standard Core Add-On 2 Core – 16 Core',
  '\\n \\n \\n \\nMicrosoft Windows Server 2022 Standard Core Add-On 2 Core – 16 Core \\nErweitern Sie Ihre Server-Lizenzierung flexibel – von 2 bis 16 zusätzliche Cores für maximale Skalierbarkeit \\n \\n \\n \\n \\n \\n \\n \\nModerne Server-Prozessoren verfügen über immer mehr CPU-Cores. Dabei reicht die Standard-Basislizenz von 16 Cores oft nicht mehr aus. Genau hier setzt Microsoft Windows Server 2022 Standard Core Add-On an. Denn diese Zusatzlizenzen erweitern Ihre bestehende Server-Lizenz flexibel um 2 bis 16 weitere Cores. Außerdem erfüllen Sie damit Microsofts Core-basiertes Lizenzmodell vollständig. Folglich können Sie leistungsstarke Server mit 20, 24, 32 oder mehr Cores legal betreiben. Zusätzlich profitieren Sie von allen Enterprise-Features wie Hyper-V, Storage Spaces Direct und erweiterten ',
  'Microsoft Windows Server 2022 Standard Core Add-On (2–16 Core) zur rechtssicheren Erweiterung Ihrer Server-Lizenz. Original Microsoft Lizenz, sofort lieferbar.',
  0,
  NULL,
  'SK24-54000301',
  'Microsoft Windows',
  'https://softwareking24.de/wp-content/uploads/2025/12/Microsoft-Windows-Server-2022-Standard-Core-Add-On-2-Core-–-16-Core.jpeg',
  1,
  999,
  datetime('now')
);

