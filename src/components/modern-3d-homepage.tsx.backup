    <script>
      // Smooth scroll function
      function scrollToSection(id) {
        document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
      }
      
      // Load products dynamically
      async function loadProducts() {
        try {
          // Load Windows products
          const windowsResponse = await axios.get('/api/products?category=windows&limit=4');
          if (windowsResponse.data.success && windowsResponse.data.data.length > 0) {
            renderProducts('windows-products', windowsResponse.data.data);
          }
          
          // Load Office products
          const officeResponse = await axios.get('/api/products?category=office&limit=4');
          if (officeResponse.data.success && officeResponse.data.data.length > 0) {
            renderProducts('office-products', officeResponse.data.data);
          }
          
          // Load Server products
          const serverResponse = await axios.get('/api/products?category=server&limit=4');
          if (serverResponse.data.success && serverResponse.data.data.length > 0) {
            renderProducts('server-products', serverResponse.data.data);
          }
        } catch (error) {
          console.error('Error loading products:', error);
        }
      }
      
      function renderProducts(containerId, products) {
        const container = document.getElementById(containerId);
        container.innerHTML = products.map(product => \`
          <div class="product-card-3d">
            <div class="product-icon-3d">
              <i class="\${getProductIcon(product.category_name)}"></i>
            </div>
            <h3>\${product.name}</h3>
            <div class="product-meta">
              <span class="meta-tag">Lifetime</span>
              <span class="meta-tag">Instant</span>
            </div>
            <p class="description">\${product.short_description || 'Genuine license with instant delivery'}</p>
            <div class="product-footer">
              <div class="price-3d">
                <span class="currency">€</span>\${(product.discount_price || product.base_price).toFixed(2)}
              </div>
              <button class="buy-btn-3d" onclick="window.location.href='/produkte/\${product.slug}'">
                <i class="fas fa-shopping-cart" style="margin-right: 6px;"></i>
                Buy Now
              </button>
            </div>
          </div>
        \`).join('');
      }
      
      function getProductIcon(category) {
        if (category && category.toLowerCase().includes('windows')) return 'fab fa-windows';
        if (category && category.toLowerCase().includes('office')) return 'fab fa-microsoft';
        if (category && category.toLowerCase().includes('server')) return 'fas fa-server';
        return 'fas fa-key';
      }
      
      // Load products on page load
      document.addEventListener('DOMContentLoaded', loadProducts);
    </script>
</body>
</html>
  `;
