# =============================================================================
# SoftwareKing24 - Environment Variables Template
# =============================================================================
# Copy this file to .dev.vars and fill in your actual values
# NEVER commit .dev.vars to git (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# 1. CLOUDFLARE API TOKEN
# -----------------------------------------------------------------------------
# Where to get: https://dash.cloudflare.com/profile/api-tokens
# Click "Create Token" → Use "Edit Cloudflare Workers" template
# Or create custom token with permissions:
#   - D1: Edit
#   - Workers Scripts: Edit
#   - Pages: Edit
#   - Account Settings: Read
# -----------------------------------------------------------------------------
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# -----------------------------------------------------------------------------
# 2. STRIPE PAYMENT KEYS
# -----------------------------------------------------------------------------
# Where to get: https://dashboard.stripe.com/test/apikeys
# For production: https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
# Test Keys (for development)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Webhook Secret (from Stripe Dashboard → Webhooks)
# Local webhook URL: http://localhost:3000/api/payments/stripe/webhook
# Production webhook URL: https://your-domain.com/api/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# -----------------------------------------------------------------------------
# 3. SENDGRID EMAIL API
# -----------------------------------------------------------------------------
# Where to get: https://app.sendgrid.com/settings/api_keys
# Click "Create API Key" → Full Access
# Don't forget to verify your sender email!
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@your-domain.com
SENDGRID_FROM_NAME=SoftwareKing24

# -----------------------------------------------------------------------------
# 4. SECURITY SECRETS (Generate random 32-byte strings)
# -----------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Or use: openssl rand -hex 32
# -----------------------------------------------------------------------------
JWT_SECRET=your_32_byte_random_jwt_secret_here
CSRF_SECRET=your_32_byte_random_csrf_secret_here

# -----------------------------------------------------------------------------
# 5. APPLICATION SETTINGS
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000
PORT=3000

# -----------------------------------------------------------------------------
# 6. OPTIONAL: PAYPAL INTEGRATION (if needed)
# -----------------------------------------------------------------------------
# PAYPAL_CLIENT_ID=your_paypal_client_id_here
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
# PAYPAL_MODE=sandbox  # or 'live' for production

